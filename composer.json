{
    "name": "groupesti/laravel-ca-oid",
    "description": "OID (Object Identifier) registry for the Laravel CA system",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "groupesti/laravel-ca": "^0.1",
        "illuminate/support": "^12.0",
        "illuminate/database": "^12.0",
        "illuminate/console": "^12.0",
        "illuminate/events": "^12.0",
        "illuminate/routing": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CA\\Oid\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CA\\Oid\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CA\\Oid\\OidServiceProvider"
            ],
            "aliases": {
                "CaOid": "CA\\Oid\\Facades\\CaOid"
            }
        }
    },
    "minimum-stability": "stable"
}
